<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/stylesheets/style.css">
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>
<div class="p-10 text-white bg-zinc-900">
    <a href="/" class="px-6 py-3 mb-6 inline-block bg-blue-500/20 border border-blue-400/30 rounded-lg backdrop-blur-md hover:bg-blue-500/30 transition-all">Home</a>
    <h1 class="text-3xl tracking-tighter mb-3">All Users</h1>

</div>
    <div class="w-full h-full p-10 text-white bg-zinc-900 overflow-scroll flex flex-col gap-3 flex-wrap scrollbar-hide">
         <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <% if(users.length > 0) { %>
                <% users.forEach(user => { %>
            <div class="backdrop-blur-md bg-white/10 border border-white/20 rounded-xl p-6 shadow-lg hover:shadow-xl transition-shadow">
                <img src="<%= user.image %>" alt="<%= user.name %>" class="w-full h-48 object-cover rounded-lg mb-4">
                <h2 class="text-xl font-semibold text-white mb-2"><%= user.name %></h2>
                <p class="text-gray-300 text-sm mb-4"><%= user.email %></p>
                <div class="flex gap-2">
                    <div class="cursor-pointer backdrop-blur-lg bg-blue-500/20 text-blue-300 border-2 border-blue-400/50 px-3 py-1 rounded-md hover:bg-blue-500/30 hover:border-blue-300 transition-all duration-200 shadow-lg shadow-blue-500/20">
                        <a class="inline-block font-medium" href="/update/<%= user._id %>">Edit</a>
                    </div>
                    <div class="cursor-pointer backdrop-blur-lg bg-red-500/20 text-red-300 border-2 border-red-400/50 px-3 py-1 rounded-md hover:bg-red-500/30 hover:border-red-300 transition-all duration-200 shadow-lg shadow-red-500/20">
                        <a class="inline-block font-medium" href="/delete/<%= user._id %>">Delete</a>
                    </div>
                </div>
            </div>
            <% }); %>
           <% } else { %>
                <h1 class="item-center text-3xl text-white">No users found.</h1>
            <% } %>
            
        </div>
    </div>
</body>
</html>
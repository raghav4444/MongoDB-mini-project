<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Node_Project1</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="text-white main w-full min-h-screen bg-zinc-900 p-10">
        <a href="/" class="px-6 py-3 mb-6 inline-block bg-blue-500/20 border border-blue-400/30 rounded-lg backdrop-blur-md hover:bg-blue-500/30 transition-all">Home</a>
        <form action="/update/<%= user._id %>" method="POST">
            <input class="text-gray-400 block px-3 py-2 w-1/4 rounded-md outline-none bg-zinc-800 edit-none" type="text" name="previous" placeholder="Previous Name" value="<%= user.name %>" readonly>
            <input class="block px-3 py-2 w-1/4 rounded-md outline-none bg-zinc-800 mt-2" type="text" name="newname" placeholder="New Name">
            <input class="mt-2 bg-yellow-600 cursor-pointer px-5 py-2" type="submit" value="Update Name">
        </form>    
    </div>
</body>
</html>